{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode"],
  "autoupdate": true,
  "default_agent": "plan",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": false,
    },
    "framelink": {
      "type": "local",
      "command": [ "bunx", "figma-developer-mcp", "--figma-api-key={env:FIGMA_API_KEY}", "--stdio" ],
      "enabled": false,
    },
    "shadcn": {
      "type": "local",
      "command": ["bunx", "shadcn@latest", "mcp"],
      "enabled": false,
    },
  },
  "model": "opencode/big-pickle",
  "permission": {
    "bash": "ask",
    "doom_loop": "ask",
    "edit": "ask",
    "external_directory": "ask",
    "lsp": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "skill": "ask",
    "task": "ask",
  },
  "provider": {
    "aihubmix": {
      "models": {
        "coding-glm-5-free": {},
        "coding-minimax-m2.5-free": {},
        "kimi-for-coding-free": {},
        "mimo-v2-flash-free": {},
      },
      "whitelist": [],
    },
    "anthropic": {
      "whitelist": ["claude-haiku-4-5", "claude-opus-4-6", "claude-sonnet-4-6"],
    },
    "github-copilot": { "whitelist": ["claude-haiku-4.5"] },
    "github-models": { "whitelist": [] },
    "google": { "whitelist": [] },
    "nvidia": {
      "whitelist": [
        "deepseek-ai/deepseek-v3.2",
        "minimaxai/minimax-m2.1",
        "moonshotai/kimi-k2-thinking",
        "moonshotai/kimi-k2.5",
        "z-ai/glm4.7",
        "z-ai/glm5",
      ],
    },
    "ollama-cloud": {
      "whitelist": [ "gemini-3-flash-preview", "glm-5", "kimi-k2.5", "minimax-m2.5" ],
    },
    "openrouter": {
      "models": {
        "openrouter/auto": {
          "name": "Auto Router",
          "cost": { "input": 5, "output": 25 },
          "limit": { "context": 1000000, "output": 1000000 },
          "modalities": {
            "input": ["text", "image", "audio", "pdf", "video"],
            "output": ["text", "image"],
          },
        },
        "openrouter/free": {
          "name": "Free Models Router",
          "cost": { "input": 0, "output": 0 },
          "limit": { "context": 100000, "output": 100000 },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
          "reasoning": true,
        },
        "xiaomi/mimo-v2-flash": {
          "name": "Xiaomi: MiMo-V2-Flash",
          "cost": { "input": 0.1, "output": 0.3 },
          "limit": { "context": 262144, "output": 32000 },
          "modalities": { "input": ["text"], "output": ["text"] },
          "reasoning": true,
        },
      },
      "whitelist": [
        "anthropic/claude-haiku-4.5",
        "anthropic/claude-opus-4.6",
        "anthropic/claude-sonnet-4.6",
        "arcee-ai/trinity-large-preview:free",
        "deepseek/deepseek-v3.2",
        "google/gemini-3-flash-preview",
        "google/gemini-3.1-pro-preview-customtools",
        "minimax/minimax-m2.5",
        "moonshotai/kimi-k2-thinking",
        "moonshotai/kimi-k2.5",
        "openrouter/auto",
        "openrouter/free",
        "openrouter/sherlock-dash-alpha",
        "openrouter/sherlock-think-alpha",
        "stepfun/step-3.5-flash:free",
        "x-ai/grok-4",
        "x-ai/grok-4.1-fast",
        "x-ai/grok-code-fast-1",
        "xiaomi/mimo-v2-flash",
        "z-ai/glm-4.5v",
        "z-ai/glm-5",
      ],
    },
    "zai-coding-plan": {
      "whitelist": [
        "glm-4.5-air",
        "glm-4.6v",
        "glm-4.7",
        "glm-4.7-flash",
        "glm-5",
      ],
    },
  },
  "small_model": "opencode/minimax-m2.5-free",
}
