{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": { "color": { "1": "yellow", "2": "green" } },
  "display": {
    "separator": ": ",
    "constants": [],
  },
  "modules": [
    "separator",
    {
      "type": "command",
      "key": "Pacman Updates",
      "text": "pacman -Qu | wc -l",
    },
    {
      "type": "command",
      "key": "Flatpak",
      "text": "flatpak list | grep -v ^Name | grep -c '.'",
    },
    {
      "type": "command",
      "key": "Bun (Global)",
      "text": "bun pm -g ls | grep -v node_modules | wc -l",
    },
    {
      "type": "command",
      "key": "AppMan",
      "text": "appman -f | grep 'MANAGED BY' | awk '{print $4}",
    },
    {
      "type": "command",
      "key": "Bin",
      "text": "bin list | grep -v '^Path' | grep -c '.'",
    },
    { "type": "command", "key": "UV", "text": "uv tool list | grep -c ' v'" },
    "separator",
    {
      "type": "command",
      "key": "Anomaly (OpenCode)",
      "text": "opencode --version",
    },
    { "type": "command", "key": "Anthropic", "text": "claude --version" },
    {
      "type": "command",
      "key": "Anysphere (Cursor)",
      "text": "cursor-agent --version",
    },
  ],
}
